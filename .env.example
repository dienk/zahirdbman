# zahirdbman configuration — copy to .env and adjust.

# HTTP listen address. If unset, the app uses :$PORT (PaaS convention) or :8080.
ZDBM_ADDR=:8080

# PostgreSQL server connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=prefer

# Maintenance database used for server-wide operations
ZDBM_ADMIN_DB=postgres

# Alternatively, provide a single connection URL (used by many PaaS platforms).
# Explicit PG* variables above override individual fields parsed from it.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Where connection profiles are persisted (defaults to the OS config dir).
# ZDBM_PROFILES=/data/profiles.json
